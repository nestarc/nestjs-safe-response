{
  "name": "nestjs-safe-response",
  "version": "0.13.0",
  "description": "Standardized API response wrapper for NestJS with Swagger integration, pagination, and custom error code mapping",
  "author": "ksyq12",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ksyq12/nestjs-safe-response.git"
  },
  "homepage": "https://github.com/ksyq12/nestjs-safe-response#readme",
  "bugs": {
    "url": "https://github.com/ksyq12/nestjs-safe-response/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "nestjs",
    "response",
    "interceptor",
    "decorator",
    "swagger",
    "pagination",
    "api",
    "wrapper"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint src/",
    "test": "jest",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config test/jest-e2e.json",
    "test:types": "npm run build && tsd --files index.test-d.ts",
    "bench": "npx ts-node test/benchmark.ts",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "@nestjs/swagger": "^8.0.0 || ^11.0.0",
    "nestjs-cls": "^4.0.0 || ^5.0.0",
    "nestjs-i18n": "^10.0.0 || ^11.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "nestjs-i18n": {
      "optional": true
    },
    "nestjs-cls": {
      "optional": true
    }
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@eslint/js": "^10.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/platform-fastify": "^11.1.17",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/testing": "^11.1.17",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/supertest": "^7.2.0",
    "class-transformer": "^0.5.1",
    "eslint": "^10.1.0",
    "jest": "^30.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsd": "^0.33.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.58.0"
  },
  "engines": {
    "node": ">=18"
  }
}
