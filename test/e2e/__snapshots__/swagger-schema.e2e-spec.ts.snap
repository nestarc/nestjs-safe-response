{
  "ErrorDetailDto": {
    "properties": {
      "code": {
        "example": "BAD_REQUEST",
        "type": "string",
      },
      "details": {
        "example": [
          "email must be an email",
          "name should not be empty",
        ],
        "type": "object",
      },
      "message": {
        "example": "Validation failed",
        "type": "string",
      },
    },
    "required": [
      "code",
      "message",
    ],
    "type": "object",
  },
  "PaginationMetaDto": {
    "properties": {
      "hasNext": {
        "example": true,
        "type": "boolean",
      },
      "hasPrev": {
        "example": false,
        "type": "boolean",
      },
      "limit": {
        "example": 20,
        "type": "number",
      },
      "page": {
        "example": 1,
        "type": "number",
      },
      "total": {
        "example": 100,
        "type": "number",
      },
      "totalPages": {
        "example": 5,
        "type": "number",
      },
      "type": {
        "enum": [
          "offset",
        ],
        "example": "offset",
        "type": "string",
      },
    },
    "required": [
      "page",
      "limit",
      "total",
      "totalPages",
      "hasNext",
      "hasPrev",
    ],
    "type": "object",
  },
  "ResponseMetaDto": {
    "properties": {
      "pagination": {
        "$ref": "#/components/schemas/PaginationMetaDto",
      },
    },
    "type": "object",
  },
  "SafeErrorResponseDto": {
    "properties": {
